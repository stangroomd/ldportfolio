---
const title = "Stangroom UK | Sectors";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      /* DROPDOWN */
      .dropdown {
        position: relative;
      }

      .dropdown-content {
        position: absolute;
        top: 100%;
        left: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        padding: 0.5rem 0;
        display: none;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      }

      .dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 10px;
      }

      .dropdown-content a {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      .dropdown-content a:hover {
        background: rgba(255,255,255,0.05);
        opacity: 1;
      }

      .dropdown:hover .dropdown-content {
        display: block;
      }

      /* BLOBS */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        z-index: 0;
      }

      .blob.one { background: var(--accent1); top: -100px; left: -100px; }
      .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
      .blob.three { background: var(--accent3); top: 50%; left: 60%; }

      main { 
        position: relative; 
        z-index: 1;
      }

      /* HERO GRID */
      .hero {
        height: 100vh;
        display: grid;
        grid-template-rows: 3fr 2fr;
        padding-top: 70px;
      }

      /* TILE BASE */
      .tile {
        position: relative;
        width: 100%;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
        transition: transform 0.4s ease;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      /* COLOUR TINTS (same classes reused) */
      .tile.lighting::after { background: linear-gradient(to top, rgba(124,92,255,0.5), rgba(0,0,0,0.2)); }
      .tile.power::after { background: linear-gradient(to top, rgba(0,212,255,0.5), rgba(0,0,0,0.2)); }
      .tile.systems::after { background: linear-gradient(to top, rgba(255,78,205,0.5), rgba(0,0,0,0.2)); }

      .tile:hover { transform: scale(1.01); }

      /* TITLE (IDENTICAL STYLE) */
      .title-wrapper {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
        font-weight: 700;
      }

      .title-shadow {
        position: absolute;
        top: 0;
        left: 0;
        color: rgba(0,0,0,0.7);
        filter: blur(8px);
        z-index: 1;
        white-space: nowrap;
      }

      .title-gradient {
        position: relative;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 2;
        white-space: nowrap;
      }

      /* BOTTOM SPLIT */
      .bottom { display: grid; grid-template-columns: 1fr 1fr; }

      /* MOBILE FIX (FINAL) */
      @media (max-width: 800px) {
        .hero {
          display: flex;
          flex-direction: column;
          height: calc(100vh - 70px);
          padding-top: 0;
        }

        .tile {
          flex: 1;
          min-height: 0;
          padding: 1.5rem;
        }

        .bottom {
          display: contents;
        }
      }

      /* SECTIONS */
      section {
        min-height: 100vh;
        padding: 5rem 2rem;
        max-width: 900px;
        margin: 0 auto;
      }

      section h2 { font-size: 2.2rem; margin-bottom: 1rem; }

      section p {
        color: var(--muted);
        line-height: 1.7;
      }

      .divider {
        width: 60px;
        height: 4px;
        margin: 1rem 0 2rem;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
      }

      /* FOOTER (MATCHED) */
      footer {
        padding: 3rem 2rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        text-align: center;
      }

      footer p { color: var(--muted); }
    </style>
  </head>

  <body>

    <!-- NAVBAR -->
    <nav>
      <div></div>
      <div class="nav-links">
        <div class="dropdown">
          <a href="#">Services</a>
          <div class="dropdown-content">
            <a href="/sectors">Explore by sector</a>
            <a href="/indev">Explore by discipline</a>
          </div>
        </div>
        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <!-- BLOBS -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <main>

      <!-- HERO -->
      <div class="hero">

        <!-- LIVE EVENTS -->
        <a href="#events" class="tile lighting" style="background-image: url('https://images.unsplash.com/photo-1506157786151-b8491531f063');">
          <h1 class="title-wrapper">
            <span class="title-shadow">Live Events</span>
            <span class="title-gradient">Live Events</span>
          </h1>
        </a>

        <!-- FILM + BROADCAST -->
        <div class="bottom">

          <a href="#film" class="tile power" style="background-image: url('https://images.unsplash.com/photo-1485846234645-a62644f84728');">
            <h2 class="title-wrapper">
              <span class="title-shadow">Film</span>
              <span class="title-gradient">Film</span>
            </h2>
          </a>

          <a href="#broadcast" class="tile systems" style="background-image: url('https://images.unsplash.com/photo-1581091012184-7c6c43f1e6c4');">
            <h2 class="title-wrapper">
              <span class="title-shadow">Broadcast</span>
              <span class="title-gradient">Broadcast</span>
            </h2>
          </h2>
          </a>

        </div>
      </div>

      <!-- SECTIONS -->
      <section id="events">
        <h2>Live Events</h2>
        <div class="divider"></div>
        <p>Lighting, power, and systems integration for concerts, festivals, and large-scale live productions.</p>
      </section>

      <section id="film">
        <h2>Film</h2>
        <div class="divider"></div>
        <p>On-set lighting, temporary power distribution, and technical systems for film production environments.</p>
      </section>

      <section id="broadcast">
        <h2>Broadcast</h2>
        <div class="divider"></div>
        <p>Studio and outside broadcast systems, networking, RF coordination, and integrated technical delivery.</p>
      </section>

      <!-- FOOTER -->
      <footer>
        <div style="max-width: 900px; margin: 0 auto;">
          <h3 style="margin-bottom: 1rem;">Contact</h3>

          <p style="color: var(--muted); line-height: 1.7;">
            Email:
            <a href="mailto:enquiries@stangroom.uk" style="color: var(--accent2); text-decoration: underline;">
              enquiries@stangroom.uk
            </a><br />

            Phone: +44 (0)1483 342 447<br />

            Based in the UK — available for live events, film & broadcast
          </p>

          <div style="margin-top: 2rem;">
            <h3 style="margin-bottom: 1rem;">Quick Links</h3>

            <p style="color: var(--muted); line-height: 1.8;">
              <a href="/mission-statement" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">
                Mission Statement
              </a>

              <a href="/reports-policies" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">
                Reports, certifications and policies
              </a>
            </p>
          </div>
        </div>
      </footer>

    </main>
  </body>
</html>
