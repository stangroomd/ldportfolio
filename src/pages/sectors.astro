---
const title = "Stangroom UK";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR (IDENTICAL TO INDEV) */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      /* DROPDOWN (IDENTICAL FIXED VERSION) */
      .dropdown {
        position: relative;
      }

      .dropdown-content {
        position: absolute;
        top: 100%;
        left: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        padding: 0.5rem 0;
        display: none;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      }

      .dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 10px;
      }

      .dropdown-content a {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      .dropdown-content a:hover {
        background: rgba(255,255,255,0.05);
        opacity: 1;
      }

      .dropdown:hover .dropdown-content {
        display: block;
      }

      /* BLOBS (IDENTICAL) */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        z-index: 0;
      }

      .blob.one { background: var(--accent1); top: -100px; left: -100px; }
      .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
      .blob.three { background: var(--accent3); top: 50%; left: 60%; }

      main {
        position: relative;
        z-index: 1;
      }

      /* HERO (FIXED FOR NAVBAR HEIGHT LIKE INDEV) */
      .hero {
        height: 100vh;
        display: grid;
        grid-template-rows: 3fr 2fr;
        padding-top: 70px;
      }

      /* TILE (IDENTICAL STYLE) */
      .tile {
        position: relative;
        width: 100%;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
        transition: transform 0.4s ease;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      .tile:hover {
        transform: scale(1.01);
      }

      /* TITLE SYSTEM (IDENTICAL) */
      .title-wrapper {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
      }

      .title-shadow {
        position: absolute;
        top: 0;
        left: 0;
        color: rgba(0,0,0,0.7);
        filter: blur(8px);
        z-index: 1;
        white-space: nowrap;
      }

      .title-gradient {
        position: relative;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 2;
        white-space: nowrap;
      }

      .bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      @media (max-width: 800px) {
        .hero { grid-template-rows: 1fr 1fr; }
        .bottom { grid-template-columns: 1fr; }
      }

      /* SECTIONS (IDENTICAL BASE) */
      section {
        min-height: 100vh;
        padding: 5rem 2rem;
        max-width: 900px;
        margin: 0 auto;

        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease, transform 0.8s ease;
      }

      section.visible {
        opacity: 1;
        transform: translateY(0);
      }

      section h2 {
        font-size: 2.2rem;
        margin-bottom: 1rem;
      }

      section p {
        color: var(--muted);
        line-height: 1.7;
      }

      .divider {
        width: 60px;
        height: 4px;
        margin: 1rem 0 2rem;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
      }

      /* SCROLL BUTTON */
      .scroll-button {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        border-radius: 8px;
        text-decoration: none;
      }
    </style>
  </head>

  <body>

    <!-- NAVBAR (IDENTICAL INDEV) -->
    <nav>
      <div></div>

      <div class="nav-links">
        <div class="dropdown">
          <a href="#">Services</a>
          <div class="dropdown-content">
            <a href="/sectors">Explore by sector</a>
            <a href="/indev">Explore by discipline</a>
          </div>
        </div>

        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <!-- BLOBS -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <main>

      <!-- HERO -->
      <div class="hero">

        <!-- LIVE EVENTS (APPROVED IMAGE) -->
        <a href="#events"
           class="tile"
           style="background-image: url('https://images.unsplash.com/photo-1507874457470-272b3c8d8ee2?w=1600&h=900&fit=crop&q=80');">
          <h1 class="title-wrapper">
            <span class="title-shadow">Live Events</span>
            <span class="title-gradient">Live Events</span>
          </h1>
        </a>

        <div class="bottom">

          <a href="#film"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h1 class="title-wrapper">
              <span class="title-shadow">Film</span>
              <span class="title-gradient">Film</span>
            </h1>
          </a>

          <a href="#broadcast"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h1 class="title-wrapper">
              <span class="title-shadow">Broadcast</span>
              <span class="title-gradient">Broadcast</span>
            </h1>
          </a>

        </div>
      </div>

      <!-- CONTENT -->
      <section id="events">
        <h2>Live Events</h2>
        <div class="divider"></div>
        <p>Full technical delivery for concerts, festivals, touring productions, and corporate live events.</p>
      </section>

      <section id="film">
        <h2>Film</h2>
        <div class="divider"></div>
        <p>On-location and studio support for film production with integrated lighting and power workflows.</p>
      </section>

      <section id="broadcast">
        <h2>Broadcast</h2>
        <div class="divider"></div>
        <p>Broadcast-ready infrastructure supporting live transmission and multi-camera production systems.</p>
      </section>

      <!-- FOOTER -->
      <footer id="footer">
        <h3>Contact</h3>
        <p>
          Email: <a href="mailto:enquiries@stangroom.uk" style="color: var(--accent2); text-decoration: underline;">enquiries@stangroom.uk</a><br />
          Phone: +44 (0)1483 342 447<br />
          Based in the UK — available for live events, film & broadcast
        </p>

        <div style="margin-top: 2rem;">
          <h3>Quick Links</h3>
          <p>
            <a href="/mission-statement" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">Mission Statement</a>
            <a href="/reports-policies" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">Reports, certifications and policies</a>
          </p>
        </div>
      </footer>

    </main>

    <!-- SCROLL ANIMATION (MATCHING INDEV STYLE) -->
    <script>
      const items = document.querySelectorAll('.tile, section');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.15 });

      items.forEach(el => observer.observe(el));
    </script>

  </body>
</html>
