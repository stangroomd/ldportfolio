---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Sectors | Stangroom UK">

  <Fragment slot="navbar">
    <Navbar />
  </Fragment>

  <main>
    <!-- HERO -->
    <div class="hero">
      
      <!-- LIVE EVENTS -->
      <a href="#events" class="tile lighting" style="background-image: url('https://images.unsplash.com/photo-1506157786151-b8491531f063');">
        <h1 class="title-wrapper">
          <span class="title-shadow">Live Events</span>
          <span class="title-gradient">Live Events</span>
        </h1>
      </a>

      <!-- FILM + BROADCAST -->
      <div class="bottom">

        <a href="#film" class="tile power" style="background-image: url('https://images.unsplash.com/photo-1485846234645-a62644f84728');">
          <h2 class="title-wrapper">
            <span class="title-shadow">Film</span>
            <span class="title-gradient">Film</span>
          </h2>
        </a>

        <a href="#broadcast" class="tile systems" style="background-image: url('https://images.unsplash.com/photo-1581091012184-7c6c43f1e6c4');">
          <h2 class="title-wrapper">
            <span class="title-shadow">Broadcast</span>
            <span class="title-gradient">Broadcast</span>
          </h2>
        </a>

      </div>
    </div>

    <!-- SECTIONS -->
    <section id="events">
      <h2>Live Events</h2>
      <div class="divider"></div>
      <p>Lighting, power, and systems integration for concerts, festivals, and large-scale live productions.</p>
    </section>

    <section id="film">
      <h2>Film</h2>
      <div class="divider"></div>
      <p>On-set lighting, temporary power distribution, and technical systems for film production environments.</p>
    </section>

    <section id="broadcast">
      <h2>Broadcast</h2>
      <div class="divider"></div>
      <p>Studio and outside broadcast systems, networking, RF coordination, and integrated technical delivery.</p>
    </section>
  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>

  <style>
    /* KEEP ORIGINAL LOGIC */
    .hero {
      height: 100vh;
      display: grid;
      grid-template-rows: 3fr 2fr;
      padding-top: 70px; /* IMPORTANT: keep this */
    }

    .tile {
      position: relative;
      width: 100%;
      display: flex;
      align-items: flex-end;
      padding: 2.5rem;
      text-decoration: none;
      background-size: cover;
      background-position: center;
      transition: transform 0.4s ease;
    }

    .tile::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
    }

    .tile.lighting::after {
      background: linear-gradient(to top, rgba(124,92,255,0.5), rgba(0,0,0,0.2));
    }

    .tile.power::after {
      background: linear-gradient(to top, rgba(0,212,255,0.5), rgba(0,0,0,0.2));
    }

    .tile.systems::after {
      background: linear-gradient(to top, rgba(255,78,205,0.5), rgba(0,0,0,0.2));
    }

    .tile:hover {
      transform: scale(1.01);
    }

    .title-wrapper {
      position: relative;
      font-size: clamp(2rem, 4vw, 3.5rem);
      line-height: 1;
      font-weight: 700;
    }

    .title-shadow {
      position: absolute;
      top: 0;
      left: 0;
      color: rgba(0,0,0,0.7);
      filter: blur(8px);
      z-index: 1;
      white-space: nowrap;
    }

    .title-gradient {
      position: relative;
      background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      z-index: 2;
      white-space: nowrap;
    }

    .bottom {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* MOBILE (keep your working version) */
    @media (max-width: 800px) {
      .hero {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 70px);
        padding-top: 0;
      }

      .tile {
        flex: 1;
        min-height: 0;
        padding: 1.5rem;
      }

      .bottom {
        display: contents;
      }
    }

    section {
      min-height: 100vh;
      padding: 5rem 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    section h2 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
    }

    section p {
      color: var(--muted);
      line-height: 1.7;
    }

    .divider {
      width: 60px;
      height: 4px;
      margin: 1rem 0 2rem;
      background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
    }
  </style>

</BaseLayout>
