---
const title = "Sectors | Stangroom UK";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR (copied from indev style intent) */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      /* DROPDOWN (same as homepage working version) */
      .dropdown {
        position: relative;
      }

      .dropdown-content {
        position: absolute;
        top: 100%;
        left: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        padding: 0.5rem 0;
        display: none;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      }

      .dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 10px;
      }

      .dropdown-content a {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      .dropdown-content a:hover {
        background: rgba(255,255,255,0.05);
        opacity: 1;
      }

      .dropdown:hover .dropdown-content {
        display: block;
      }

      main {
        padding-top: 70px;
      }

      /* HERO GRID (IMPORTANT FIX: full viewport minus nav) */
      .hero {
        height: calc(100vh - 70px);
        display: grid;
        grid-template-rows: 3fr 2fr;
      }

      .tile {
        position: relative;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
        overflow: hidden;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      .title {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 1;
      }

      .bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      @media (max-width: 800px) {
        .hero {
          grid-template-rows: 1fr 1fr;
        }
        .bottom {
          grid-template-columns: 1fr;
        }
      }

      section {
        min-height: 100vh;
        padding: 5rem 2rem;
        max-width: 900px;
        margin: 0 auto;
      }

      section h2 {
        font-size: 2.2rem;
        margin-bottom: 1rem;
      }

      section p {
        color: var(--muted);
        line-height: 1.7;
      }
    </style>
  </head>

  <body>

    <!-- NAVBAR -->
    <nav>
      <div></div>

      <div class="nav-links">

        <div class="dropdown">
          <a href="#">Services</a>
          <div class="dropdown-content">
            <a href="/sectors">Explore by sector</a>
            <a href="/indev">Explore by discipline</a>
          </div>
        </div>

        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <div class="hero">

        <!-- LIVE EVENTS -->
        <a href="#events"
           class="tile"
           style="background-image: url('https://images.unsplash.com/photo-1507874457470-272b3c8d8ee2?w=1600&h=900&fit=crop&q=80');">
          <h1 class="title">Live Events</h1>
        </a>

        <div class="bottom">

          <!-- FILM -->
          <a href="#film"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h2 class="title">Film</h2>
          </a>

          <!-- BROADCAST -->
          <a href="#broadcast"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h2 class="title">Broadcast</h2>
          </a>

        </div>
      </div>

      <!-- CONTENT -->

      <section id="events">
        <h2>Live Events</h2>
        <p>
          Full technical delivery for concerts, festivals, touring productions, and corporate live events.
        </p>
        <p>
          Lighting, power, and systems integration delivered with reliability under pressure in fast-moving environments.
        </p>
      </section>

      <section id="film">
        <h2>Film</h2>
        <p>
          On-location and studio support for film production, ensuring lighting and power integrate seamlessly with crew workflows.
        </p>
      </section>

      <section id="broadcast">
        <h2>Broadcast</h2>
        <p>
          Robust, broadcast-ready infrastructure supporting live transmission, studio production, and multi-camera workflows.
        </p>
      </section>

    </main>

  </body>
</html>
