---
const title = "Sectors | Stangroom UK";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      nav {
        position: fixed;
        top: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      main {
        padding-top: 70px;
      }

      /* HERO GRID */
      .hero {
        height: 100vh;
        display: grid;
        grid-template-rows: 3fr 2fr;
      }

      .tile {
        position: relative;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      .title {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 1;
      }

      .bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      @media (max-width: 800px) {
        .bottom {
          grid-template-columns: 1fr;
        }
      }

      section {
        min-height: 100vh;
        padding: 5rem 2rem;
        max-width: 900px;
        margin: 0 auto;
      }

      section h2 {
        font-size: 2.2rem;
        margin-bottom: 1rem;
      }

      section p {
        color: var(--muted);
        line-height: 1.7;
      }
    </style>
  </head>

  <body>

    <nav>
      <div></div>
      <div class="nav-links">
        <a href="/sectors">Sectors</a>
        <a href="/indev">Disciplines</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <div class="hero">

        <!-- LIVE EVENTS (LOCKED IMAGE) -->
        <a href="#events"
           class="tile"
           style="background-image: url('https://images.unsplash.com/photo-1507874457470-272b3c8d8ee2?w=1600&h=900&fit=crop&q=80');">
          <h1 class="title">Live Events</h1>
        </a>

        <div class="bottom">

          <!-- FILM (placeholder for now) -->
          <a href="#film"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h2 class="title">Film</h2>
          </a>

          <!-- BROADCAST (placeholder for now) -->
          <a href="#broadcast"
             class="tile"
             style="background-image: url('/images/placeholder.jpg');">
            <h2 class="title">Broadcast</h2>
          </a>

        </div>
      </div>

      <!-- LIVE EVENTS -->
      <section id="events">
        <h2>Live Events</h2>
        <p>
          Delivering complete technical solutions for live environments — from touring productions and festivals to corporate events.
        </p>
        <p>
          Covering lighting, power, and systems integration, with a focus on reliability, safety, and seamless execution under live conditions.
        </p>
      </section>

      <!-- FILM -->
      <section id="film">
        <h2>Film</h2>
        <p>
          Supporting film productions with adaptable technical services that integrate cleanly with on-set workflows.
        </p>
      </section>

      <!-- BROADCAST -->
      <section id="broadcast">
        <h2>Broadcast</h2>
        <p>
          Providing robust, broadcast-ready systems with a focus on reliability, redundancy, and integration.
        </p>
      </section>

    </main>

  </body>
</html>
