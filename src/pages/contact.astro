---
const title = "Contact | Stangroom UK";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR (MATCHING OTHER PAGES) */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      .dropdown {
        position: relative;
      }

      .dropdown-content {
        position: absolute;
        top: 100%;
        left: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        padding: 0.5rem 0;
        display: none;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      }

      .dropdown:hover .dropdown-content {
        display: block;
      }

      .dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        height: 10px;
      }

      .dropdown-content a {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      .dropdown-content a:hover {
        background: rgba(255,255,255,0.05);
        opacity: 1;
      }

      /* BLOBS */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        z-index: 0;
      }

      .blob.one { background: var(--accent1); top: -100px; left: -100px; }
      .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
      .blob.three { background: var(--accent3); top: 50%; left: 60%; }

      main {
        position: relative;
        z-index: 1;
        padding-top: 70px;
      }

      /* HERO */
      .hero {
        text-align: center;
        padding: 6rem 2rem 3rem;
      }

      .hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        margin-bottom: 1rem;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .hero p {
        color: var(--muted);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.7;
      }

      /* FORM */
      .form-wrapper {
        max-width: 700px;
        margin: 0 auto;
        padding: 2rem;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      input, textarea {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03);
        color: var(--text);
        font-size: 1rem;
      }

      textarea {
        min-height: 160px;
        resize: vertical;
      }

      button {
        padding: 0.9rem 1.5rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        transition: transform 0.2s ease;
      }

      button:hover {
        transform: scale(1.03);
      }

      footer {
        padding: 3rem 2rem;
        text-align: center;
        border-top: 1px solid rgba(255,255,255,0.1);
        margin-top: 4rem;
      }

      footer p {
        color: var(--muted);
      }
    </style>
  </head>

  <body>

    <!-- BLOBS -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <!-- NAVBAR -->
    <nav>
      <div></div>

      <div class="nav-links">
        <div class="dropdown">
          <a href="#">Services</a>
          <div class="dropdown-content">
            <a href="/sectors">Explore by sector</a>
            <a href="/indev">Explore by discipline</a>
          </div>
        </div>

        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <div class="hero">
        <h1>Contact</h1>
        <p>
          Get in touch for enquiries about live events, film, broadcast,
          or the Illuminating Futures programme.
        </p>
      </div>

      <!-- FORM -->
      <div class="form-wrapper">

        <form action="https://formspree.io/f/xdaynbyn" method="POST">
          <input type="text" name="name" placeholder="Your name" required />
          <input type="email" name="email" placeholder="Your email" required />
          <textarea name="message" placeholder="Your message" required></textarea>

          <!-- Optional: subject line -->
          <input type="hidden" name="_subject" value="New Contact Form Submission" />

          <button type="submit">Send Message</button>
        </form>

      </div>

      <!-- FOOTER -->
      <footer>
        <div style="max-width: 900px; margin: 0 auto;">
          <h3 style="margin-bottom: 1rem;">Contact</h3>

          <p style="color: var(--muted); line-height: 1.7;">
            Email:
            <a href="mailto:enquiries@stangroom.uk" style="color: var(--accent2); text-decoration: underline;">
              enquiries@stangroom.uk
            </a><br />

            Phone: +44 (0)1483 342 447<br />

            Based in the UK — available for live events, film & broadcast
          </p>

          <div style="margin-top: 2rem;">
            <h3 style="margin-bottom: 1rem;">Quick Links</h3>

            <p style="color: var(--muted); line-height: 1.8;">
              <a href="/mission-statement" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">
                Mission Statement
              </a>

              <a href="/reports-policies" style="color: var(--text); text-decoration: none; display:block; opacity:0.85;">
                Reports, certifications and policies
              </a>
            </p>
          </div>
        </div>
      </footer>

    </main>
  </body>
</html>
