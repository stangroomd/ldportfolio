---
const title = "Services";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* Background glow */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.4;
        z-index: 0;
      }

      .blob.one {
        background: var(--accent1);
        top: -100px;
        left: -100px;
      }

      .blob.two {
        background: var(--accent2);
        bottom: -150px;
        right: -100px;
      }

      .blob.three {
        background: var(--accent3);
        top: 50%;
        left: 60%;
      }

      main {
        position: relative;
        z-index: 1;
      }

      /* GRID */
      .grid {
        display: grid;
        gap: 1rem;
        padding: 1rem;
      }

      .grid-top {
        grid-template-columns: 1fr;
      }

      .grid-bottom {
        grid-template-columns: 1fr 1fr;
      }

      @media (max-width: 700px) {
        .grid-bottom {
          grid-template-columns: 1fr;
        }
      }

      /* TILE */
      .tile {
        position: relative;
        height: 260px;
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        display: flex;
        align-items: flex-end;
        padding: 1.5rem;

        background-size: cover;
        background-position: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.8),
          rgba(0, 0, 0, 0.2)
        );
      }

      .tile:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
      }

      .tile h2 {
        position: relative;
        z-index: 2;
        font-size: 1.8rem;

        background: linear-gradient(
          90deg,
          var(--accent1),
          var(--accent2),
          var(--accent3)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      /* SECTIONS */
      section {
        padding: 4rem 1.5rem;
        max-width: 900px;
        margin: 0 auto;
      }

      section h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
      }

      section p {
        color: var(--muted);
        line-height: 1.6;
      }

      .divider {
        width: 60px;
        height: 4px;
        margin: 1rem 0 2rem;
        background: linear-gradient(
          90deg,
          var(--accent1),
          var(--accent2),
          var(--accent3)
        );
        border-radius: 2px;
      }
    </style>
  </head>

  <body>
    <!-- Background -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <main>
      <!-- TOP FULL WIDTH -->
      <div class="grid grid-top">
        <a href="#lighting" class="tile" style="background-image: url('https://images.unsplash.com/photo-1507477338202-487281e6c27e');">
          <h2>Lighting</h2>
        </a>
      </div>

      <!-- TWO BELOW -->
      <div class="grid grid-bottom">
        <a href="#power" class="tile" style="background-image: url('https://images.unsplash.com/photo-1581090700227-1e8e8e3d06b6');">
          <h2>Power</h2>
        </a>

        <a href="#systems" class="tile" style="background-image: url('https://images.unsplash.com/photo-1518779578993-ec3579fee39f');">
          <h2>Systems</h2>
        </a>
      </div>

      <!-- SECTIONS -->
      <section id="lighting">
        <h2>Lighting</h2>
        <div class="divider"></div>
        <p>
          From architectural lighting design to practical installations,
          we create lighting solutions that enhance both aesthetics and
          functionality. Whether it's ambient mood lighting or precision task
          lighting, everything is tailored to your space.
        </p>
      </section>

      <section id="power">
        <h2>Power</h2>
        <div class="divider"></div>
        <p>
          Reliable and efficient power systems designed for modern demands.
          From domestic upgrades to full-scale distribution solutions,
          safety, compliance, and performance are always at the core.
        </p>
      </section>

      <section id="systems">
        <h2>Systems</h2>
        <div class="divider"></div>
        <p>
          Smart systems integration including automation, control, and
          monitoring. Bringing together technology and usability to create
          seamless environments for work or home.
        </p>
      </section>
    </main>
  </body>
</html>
