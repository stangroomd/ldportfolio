---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Mission Statement | Stangroom UK">

  <Fragment slot="navbar">
    <Navbar />
  </Fragment>

  <!-- BACKGROUND BLOBS -->
  <div class="blob one"></div>
  <div class="blob two"></div>
  <div class="blob three"></div>

  <main>

    <!-- CONTENT -->
    <section>
      <h1>Mission Statement</h1>
      <div class="divider"></div>

      <p>
        Stangroom UK exists to deliver reliable, high-quality technical services across live events, film, and broadcast.
        The focus is on practical execution, strong collaboration, and ensuring that every production runs safely and efficiently.
      </p>

      <p>
        By working across lighting, power, and systems, the aim is to provide a joined-up approach that supports both creative intent and technical requirements.
        This allows productions to operate smoothly, with clear communication between departments and dependable infrastructure on site.
      </p>

      <p>
        Alongside technical delivery, there is a strong commitment to supporting the next generation of industry professionals.
        Through real-world experience and access to live environments, emerging talent can gain meaningful insight into how productions operate.
      </p>

      <p>
        The goal is simple: deliver work that is dependable, professional, and forward-looking, while contributing positively to the wider industry.
      </p>
    </section>

    <Fragment slot="footer">
      <Footer />
    </Fragment>

  </main>

  <style>
    :global(*) {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    main {
      position: relative;
      z-index: 1;
    }

    /* BLOBS */
    .blob {
      position: fixed;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.3;
      z-index: 0;
    }

    .blob.one { background: var(--accent1); top: -100px; left: -100px; }
    .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
    .blob.three { background: var(--accent3); top: 50%; left: 60%; }

    /* CONTENT */
    section {
      max-width: 900px;
      margin: 0 auto;
      padding: 6rem 2rem;
    }

    section h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    section p {
      color: var(--muted);
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    .divider {
      width: 60px;
      height: 4px;
      margin: 1rem 0 2rem;
      background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
    }
  </style>

</BaseLayout>
