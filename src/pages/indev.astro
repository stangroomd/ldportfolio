---
const title = "Stangroom | Lighting • Power • Systems";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>

<style>
:root {
  --bg:#0b0c10;
  --text:#eaeaf0;
  --muted:#9aa0a6;
  --accent1:#7c5cff;
  --accent2:#00d4ff;
  --accent3:#ff4ecd;
}

*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:system-ui;background:var(--bg);color:var(--text);}

/* NAVBAR */
nav {
  position: fixed;
  top:0;
  width:100%;
  padding:1rem 2rem;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  z-index:100;
}

.nav-links {
  display:flex;
  gap:2rem;
}

.nav-links a {
  text-decoration:none;
  color:var(--text);
  font-size:0.95rem;
  opacity:0.8;
  transition:0.2s;
}

.nav-links a:hover { opacity:1; }

/* HERO */
.hero {
  height:100vh;
  display:grid;
  grid-template-rows:3fr 2fr;
  margin-top:60px;
}

.tile {
  position:relative;
  display:flex;
  align-items:flex-end;
  padding:2.5rem;
  background-size:cover;
  background-position:center;
  text-decoration:none;
}

.tile::after {
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
}

.bottom { display:grid; grid-template-columns:1fr 1fr; }

/* TEXT */
.title-wrapper { position:relative; font-size:3rem; }

.title-shadow {
  position:absolute;
  top:0; left:0;
  color:black;
  filter:blur(8px);
  z-index:1;
}

.title-gradient {
  position:relative;
  background:linear-gradient(90deg,var(--accent1),var(--accent2),var(--accent3));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  z-index:2;
}

/* SECTIONS */
section { padding:5rem 2rem; max-width:900px; margin:auto; }
section p { color:var(--muted); margin-top:1rem; }
ul { margin-top:1rem; line-height:1.6; }

footer { padding:3rem; text-align:center; border-top:1px solid #222; }

</style>
</head>

<body>

<nav>
  <div class="logo"></div>
  <div class="nav-links">
    <a href="/">Services</a>
    <a href="/illuminating-futures">Illuminating Futures</a>
    <a href="/contact">Contact</a>
  </div>
</nav>

<div class="hero">
  <a href="#lighting" class="tile" style="background-image:url('/images/lighting.png')">
    <div class="title-wrapper">
      <span class="title-shadow">Lighting</span>
      <span class="title-gradient">Lighting</span>
    </div>
  </a>

  <div class="bottom">
    <a href="#power" class="tile" style="background-image:url('https://images.openai.com/...')">
      <div class="title-wrapper">
        <span class="title-shadow">Power</span>
        <span class="title-gradient">Power</span>
      </div>
    </a>

    <a href="#systems" class="tile" style="background-image:url('https://images.pexels.com/photos/1054397/pexels-photo-1054397.jpeg')">
      <div class="title-wrapper">
        <span class="title-shadow">Systems</span>
        <span class="title-gradient">Systems</span>
      </div>
    </a>
  </div>
</div>

<!-- KEEP YOUR EXISTING SECTIONS HERE -->

<footer>
  Contact details here
</footer>

</body>
</html>
