---
const title = "Stangroom | Lighting • Power • Systems";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR */
      nav {
        position: fixed;
        top: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.8;
        transition: 0.2s;
      }

      .nav-links a:hover { opacity: 1; }

      /* Background blobs */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        z-index: 0;
      }

      .blob.one { background: var(--accent1); top: -100px; left: -100px; }
      .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
      .blob.three { background: var(--accent3); top: 50%; left: 60%; }

      main { position: relative; z-index: 1; }

      /* HERO GRID */
      .hero {
        height: 100vh;
        display: grid;
        grid-template-rows: 3fr 2fr;
        margin-top: 70px; /* prevents navbar overlap */
      }

      .tile {
        position: relative;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      .tile.lighting::after { background: linear-gradient(to top, rgba(124,92,255,0.5), rgba(0,0,0,0.2)); }
      .tile.power::after { background: linear-gradient(to top, rgba(0,212,255,0.5), rgba(0,0,0,0.2)); }
      .tile.systems::after { background: linear-gradient(to top, rgba(255,78,205,0.5), rgba(0,0,0,0.2)); }

      .bottom { display: grid; grid-template-columns: 1fr 1fr; }

      /* TEXT */
      .title-wrapper {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
      }

      .title-shadow {
        position: absolute;
        top: 0;
        left: 0;
        color: rgba(0,0,0,0.8);
        filter: blur(10px);
        z-index: 1;
      }

      .title-gradient {
        position: relative;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 2;
      }

      /* SECTIONS */
      section {
        min-height: 100vh;
        padding: 5rem 2rem;
        max-width: 900px;
        margin: 0 auto;
      }

      section p { color: var(--muted); line-height: 1.7; }
      ul { margin-top: 1rem; padding-left: 1.2rem; }

      .divider {
        width: 60px;
        height: 4px;
        margin: 1rem 0 2rem;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
      }

      /* BUTTON */
      .scroll-button {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.75rem 1.5rem;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        color: white;
        text-decoration: none;
        border-radius: 8px;
      }

      /* FOOTER */
      footer {
        padding: 3rem 2rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        text-align: center;
      }

      footer p { color: var(--muted); }

    </style>
  </head>

  <body>

    <!-- NAVBAR -->
    <nav>
      <div></div> <!-- Logo placeholder -->
      <div class="nav-links">
        <a href="/">Services</a>
        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <!-- Background blobs -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <main>

      <!-- HERO -->
      <div class="hero">
        <a href="#lighting" class="tile lighting" style="background-image: url('/images/lighting.png');">
          <div class="title-wrapper">
            <span class="title-shadow">Lighting</span>
            <span class="title-gradient">Lighting</span>
          </div>
        </a>

        <div class="bottom">
          <a href="#power" class="tile power" style="background-image: url('https://images.openai.com/static-rsc-4/...')">
            <div class="title-wrapper">
              <span class="title-shadow">Power</span>
              <span class="title-gradient">Power</span>
            </div>
          </a>

          <a href="#systems" class="tile systems" style="background-image: url('https://images.pexels.com/photos/1054397/pexels-photo-1054397.jpeg')">
            <div class="title-wrapper">
              <span class="title-shadow">Systems</span>
              <span class="title-gradient">Systems</span>
            </div>
          </a>
        </div>
      </div>

      <!-- (All your existing sections remain unchanged below) -->

      <!-- FOOTER -->
      <footer id="footer">
        <h3>Contact</h3>
        <p>
          Email: <a href="mailto:enquiries@stangroom.uk" style="color: var(--accent2);">enquiries@stangroom.uk</a><br />
          Phone: +44 (0)1483 342 447
        </p>
      </footer>

    </main>
  </body>
</html>
