---
const title = "Stangroom UK";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --bg: #0b0c10;
        --text: #eaeaf0;
        --muted: #9aa0a6;

        --accent1: #7c5cff;
        --accent2: #00d4ff;
        --accent3: #ff4ecd;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      /* NAVBAR */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(10px);
        z-index: 1000;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }

      .nav-links a {
        color: var(--text);
        text-decoration: none;
        font-size: 0.95rem;
        opacity: 0.85;
      }

      .nav-links a:hover {
        opacity: 1;
      }

      /* DROPDOWN (added only) */
      .dropdown {
        position: relative;
      }

      .dropdown-content {
        position: absolute;
        top: 120%;
        left: 0;
        background: rgba(0,0,0,0.9);
        backdrop-filter: blur(10px);
        border-radius: 8px;
        padding: 0.5rem 0;
        display: none;
        min-width: 200px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      }

      .dropdown-content a {
        display: block;
        padding: 0.6rem 1rem;
        font-size: 0.9rem;
        opacity: 0.85;
      }

      .dropdown-content a:hover {
        background: rgba(255,255,255,0.05);
        opacity: 1;
      }

      .dropdown:hover .dropdown-content {
        display: block;
      }

      /* Background blobs */
      .blob {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        z-index: 0;
      }

      .blob.one { background: var(--accent1); top: -100px; left: -100px; }
      .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
      .blob.three { background: var(--accent3); top: 50%; left: 60%; }

      main { 
        position: relative; 
        z-index: 1;
      }

      /* HERO GRID */
      .hero {
        height: 100vh;
        display: grid;
        grid-template-rows: 3fr 2fr;
        padding-top: 70px;
      }

      /* TILE BASE */
      .tile {
        position: relative;
        width: 100%;
        display: flex;
        align-items: flex-end;
        padding: 2.5rem;
        text-decoration: none;
        background-size: cover;
        background-position: center;
        transition: transform 0.4s ease;
      }

      .tile::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2));
      }

      /* Colour tints */
      .tile.lighting::after { background: linear-gradient(to top, rgba(124,92,255,0.5), rgba(0,0,0,0.2)); }
      .tile.power::after { background: linear-gradient(to top, rgba(0,212,255,0.5), rgba(0,0,0,0.2)); }
      .tile.systems::after { background: linear-gradient(to top, rgba(255,78,205,0.5), rgba(0,0,0,0.2)); }

      .tile:hover { transform: scale(1.01); }

      /* TWO-LAYER TEXT WITH SHADOW BEHIND */
      .title-wrapper {
        position: relative;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
      }

      .title-shadow {
        position: absolute;
        top: 0;
        left: 0;
        color: rgba(0,0,0,0.7);
        filter: blur(8px);
        z-index: 1;
        white-space: nowrap;
      }

      .title-gradient {
        position: relative;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        z-index: 2;
        white-space: nowrap;
      }

      /* BOTTOM SPLIT */
      .bottom { display: grid; grid-template-columns: 1fr 1fr; }

      @media (max-width: 800px) {
        .hero { grid-template-rows: 1fr 1fr; }
        .bottom { grid-template-columns: 1fr; }
      }

      /* SECTIONS */
      section { min-height: 100vh; padding: 5rem 2rem; max-width: 900px; margin: 0 auto; }
      section h2 { font-size: 2.2rem; margin-bottom: 1rem; }
      section p { color: var(--muted); line-height: 1.7; }
      .divider { width: 60px; height: 4px; margin: 1rem 0 2rem; background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3)); }

      /* SCROLL BUTTONS */
      .scroll-button {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
        border: none;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .scroll-button:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 15px rgba(0,0,0,0.3);
      }

      /* FOOTER */
      footer { padding: 3rem 2rem; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; }
      footer h3 { margin-bottom: 1rem; }
      footer p { color: var(--muted); }
    </style>
  </head>

  <body>

    <!-- NAVBAR -->
    <nav>
      <div></div>
      <div class="nav-links">
        <div class="dropdown">
          <a href="#">Services</a>
          <div class="dropdown-content">
            <a href="/sectors">Explore by sector</a>
            <a href="/indev">Explore by discipline</a>
          </div>
        </div>
        <a href="/illuminating-futures">Illuminating Futures</a>
        <a href="/contact">Contact</a>
      </div>
    </nav>

    <!-- Background blobs -->
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>

    <main>
      <!-- HERO -->
      <div class="hero">
        <!-- LIGHTING -->
        <a href="#lighting" class="tile lighting" style="background-image: url('/images/lighting.png');">
          <h1 class="title-wrapper">
            <span class="title-shadow">Lighting</span>
            <span class="title-gradient">Lighting</span>
          </h1>
        </a>

        <!-- POWER + SYSTEMS -->
        <div class="bottom">
          <a href="#power" class="tile power" style="background-image: url('https://images.openai.com/static-rsc-4/Z6-2wMI0_rdfCV63UWBVQ8pUT9rL6uiZbR2NpGsVlri-B8au_UWWExVDxCFrJo8zBNH9rXWJPJO1U8rVo4_l8rSu8VtdpB5dybe54LbJUiDC11KSS1zvgTsYJ42s0onuBTl85dbBNDz-YEiyQaFB1zDRrT7R3vMMqTViQGULNQSpVa9o1bSgUvgvntVl_7L2?purpose=fullsize');">
            <h2 class="title-wrapper">
              <span class="title-shadow">Power</span>
              <span class="title-gradient">Power</span>
            </h2>
          </a>

          <a href="#systems" class="tile systems" style="background-image: url('https://images.pexels.com/photos/1054397/pexels-photo-1054397.jpeg');">
            <h2 class="title-wrapper">
              <span class="title-shadow">Systems</span>
              <span class="title-gradient">Systems</span>
            </h2>
          </a>
        </div>
      </div>

      <!-- ALL ORIGINAL CONTENT CONTINUES UNCHANGED -->

      <section id="lighting">
        <h2>Lighting</h2>
        <div class="divider"></div>
        <p>Providing comprehensive lighting solutions across <strong>live events</strong>, <strong>film</strong>, and <strong>broadcast</strong>. Whether you need full turnkey services or targeted support, we can deliver exactly what your production requires.</p>
        <ul>
          <li>Full turnkey lighting solutions for events, shoots, or broadcasts</li>
          <li>Pre-production support and prep work, including design consultation</li>
          <li>Rigging and truss setup for temporary or permanent installations</li>
          <li>Automation and programming designed to support your event and crew</li>
          <li>On-site operation and technical support throughout your production</li>
        </ul>
        <p>From concept to execution - ensuring lighting is visually impactful, safe, and seamlessly integrated with your production’s workflow.</p>
        <a href="#footer" class="scroll-button">Realise your vision</a>
      </section>

      <section id="power">
        <h2>Power</h2>
        <div class="divider"></div>
        <p>Providing complete temporary power solutions for <strong>live events</strong>, <strong>film</strong>, and <strong>broadcast</strong>.</p>
        <ul>
          <li>Provision and connection of generators and distribution systems</li>
          <li>Effective coordination with other departments to ensure a balanced and reliable supply for your event</li>
          <li>Inspection, testing, and certification to <strong>BS 7671</strong>, <strong>BS 7909</strong> and all other relevant industry standards</li>
          <li>On-site support, monitoring, and troubleshooting during productions</li>
        </ul>
        <p>Ensuring reliable, compliant, and optimised power delivery for every production environment.</p>
        <a href="#footer" class="scroll-button">Power your production</a>
      </section>

      <section id="systems">
        <h2>Systems</h2>
        <div class="divider"></div>
        <p>Integrating and managing technical systems across sites and departments.</p>
        <ul>
          <li>IP Networking and distribution scaled to your production's needs</li>
          <li>RF spectrum surveying, interference analysis, and licensing</li>
          <li>Deployment of fixed-line and bonded internet connections</li>
          <li>Interfacing, integration and management of diverse systems</li>
          <li>Collaboration with dependent departments to streamline workflows</li>
        </ul>
        <p>Providing fully integrated, reliable, and scalable systems for complex productions.</p>
        <a href="#footer" class="scroll-button">Empower your techs</a>
        <a href="#footer" class="scroll-button">Empower your event</a>
      </section>

      <!-- FOOTER -->
      <footer id="footer">
        <h3>Contact</h3>
        <p>
          Email: <a href="mailto:enquiries@stangroom.uk" style="color: var(--accent2); text-decoration: underline;">enquiries@stangroom.uk</a><br />
          Phone: +44 (0)1483 342 447<br />
          Based in the UK — available for live events, film & broadcast
        </p>
      </footer>
    </main>
  </body>
</html>
