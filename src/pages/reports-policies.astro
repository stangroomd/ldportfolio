---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const title = "Reports, Certifications & Policies | Stangroom UK";
---

<BaseLayout title={title}>

  <Fragment slot="navbar">
    <Navbar />
  </Fragment>

  <!-- Background blobs -->
  <div class="blob one"></div>
  <div class="blob two"></div>
  <div class="blob three"></div>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h1>Reports, Certifications & Policies</h1>
        <div class="divider"></div>
        <p>Download key documents below.</p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="content">
      <ul>
        <li>
          <a href="/policies/Corporate_Social_Responsibility_Policy.pdf" target="_blank">
            Corporate Social Responsibility Policy (PDF)
          </a>
        </li>

        <li>
          <a href="/policies/Equality_Diversity_Inclusion_Policy.pdf" target="_blank">
            Equality, Diversity & Inclusion Policy (PDF)
          </a>
        </li>

        <li>
          <a href="/policies/Environmental_Statement.pdf" target="_blank">
            Environmental Statement (PDF)
          </a>
        </li>

        <li>
          <a href="/policies/Health_and_Safety_Policy.pdf" target="_blank">
            Health & Safety Policy (PDF)
          </a>
        </li>

        <li>
          <a href="/policies/Modern_Slavery_Statement.pdf" target="_blank">
            Modern Slavery Statement (PDF)
          </a>
        </li>

        <li>
          <a href="/policies/Data_Protection_Privacy_Policy.pdf" target="_blank">
            Data Protection & Privacy Policy (PDF)
          </a>
        </li>
      </ul>
    </section>

  </main>

  <Fragment slot="footer">
    <Footer />
  </Fragment>

  <style>
    :root {
      --bg: #0b0c10;
      --text: #eaeaf0;
      --muted: #9aa0a6;

      --accent1: #7c5cff;
      --accent2: #00d4ff;
      --accent3: #ff4ecd;
    }

    :global(*) {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .blob {
      position: fixed;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.3;
      z-index: 0;
    }

    .blob.one { background: var(--accent1); top: -100px; left: -100px; }
    .blob.two { background: var(--accent2); bottom: -150px; right: -100px; }
    .blob.three { background: var(--accent3); top: 50%; left: 60%; }

    main {
      position: relative;
      z-index: 1;
    }

    .hero {
      height: 60vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 2rem;
    }

    .hero-inner h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      margin-bottom: 1rem;
      background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .divider {
      width: 60px;
      height: 4px;
      margin: 1rem auto 1.5rem;
      background: linear-gradient(90deg, var(--accent1), var(--accent2), var(--accent3));
    }

    .hero-inner p {
      color: var(--muted);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.7;
    }

    .content {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    ul {
      list-style: none;
      margin-top: 2rem;
    }

    li {
      margin-bottom: 1rem;
    }

    li a {
      color: var(--text);
      text-decoration: none;
      opacity: 0.85;
      transition: opacity 0.2s ease;
    }

    li a:hover {
      opacity: 1;
      text-decoration: underline;
    }
  </style>

</BaseLayout>
